# Local development
DATABASE_URL=postgresql+psycopg2://cvfit:cvfit@localhost:5432/cvfit
REDIS_URL=redis://localhost:6379/0
STORAGE_BACKEND=local
STORAGE_ROOT=../data
CV_MAX_UPLOAD_MB=10
FRONTEND_TEMPLATES_DIR=../frontend/templates
FRONTEND_STATIC_DIR=../frontend/static

# Authentication/CORS. Replace the development JWT value outside local use.
JWT_SECRET_KEY=insecure-local-dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOWED_METHODS=GET,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type
ADMIN_EMAILS=

# Google Sign-In (ID-token flow). GOOGLE_CLIENT_ID is the OAuth Web client ID
# used as the verification audience. The /v1/auth/google endpoint returns 503
# until it is set. ENABLE_GOOGLE_AUTH can force the endpoint off even if set.
# This is a public client ID, not a secret — there is NO client secret for the
# Google Identity Services ID-token flow.
GOOGLE_CLIENT_ID=
ENABLE_GOOGLE_AUTH=true

# Phase 6 product flags. Share links remain disabled until privacy approval.
ENABLE_PHASE6_TARGET_JOBS=true
ENABLE_PHASE6_LEARNING=true
ENABLE_PHASE6_INTERVIEW_V2=true
ENABLE_PHASE6_HELP_ASSISTANT=true
ENABLE_PHASE6_SHARE_LINKS=false
ENABLE_PHASE6_USAGE_SHELL=true

# Phase 7 billing stays disabled. Do not add real payOS values to this file.
ENABLE_BILLING=false
ENABLE_CREDIT_GATING=false
PAYMENT_PROVIDER=payos
PAYMENT_CURRENCY=VND
PAYMENT_RETURN_URL=
PAYMENT_CANCEL_URL=
PAYOS_WEBHOOK_URL=
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Phase 8 — Realtime interview backend. Disabled by default and fail-closed.
# Set the API key only in the backend runtime environment. Never expose it to
# browser code, logs, source control, or API responses.
ENABLE_REALTIME_INTERVIEW=false
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=
OPENAI_REALTIME_VOICE=
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_SESSION_MAX_MINUTES=15
OPENAI_REALTIME_MAX_QUESTIONS=5
OPENAI_REALTIME_CLIENT_SECRET_TTL_SECONDS=60
OPENAI_REALTIME_CLIENT_SECRET_MIN_INTERVAL_SECONDS=30

# Render MVP deployment
# DATABASE_URL=postgresql+psycopg2://...
# REDIS_URL=redis://...
# STORAGE_BACKEND=s3
# S3_BUCKET=cvfit-mvp
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=
# S3_PREFIX=render/mvp
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_USE_IAM_ROLE=false
# CV_MAX_UPLOAD_MB=10
# JWT_SECRET_KEY=<generated high-entropy secret>
# CORS_ALLOWED_ORIGINS=https://your-frontend.example
# CORS_ALLOW_CREDENTIALS=false
# ENABLE_BILLING=false
# ENABLE_CREDIT_GATING=false
# ENABLE_REALTIME_INTERVIEW=false

# Local S3 smoke test
# Use docker-compose.s3.yml with a private bucket or S3-compatible provider.
# For Cloudflare R2, MinIO, Wasabi, or Backblaze B2, set S3_ENDPOINT_URL.
# Never commit real credentials.
# API_BASE_URL=http://localhost:8000
# SMOKE_TIMEOUT_SECONDS=300

# Future AWS deployment notes
# Use RDS PostgreSQL with pgvector for DATABASE_URL.
# Use ElastiCache Redis for REDIS_URL.
# Use STORAGE_BACKEND=s3 with an S3 bucket and IAM-provided credentials where possible.
